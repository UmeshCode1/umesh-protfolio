# ── Supabase (Auth + Database) ────────────────────
# Get these from: https://supabase.com/dashboard/project/<project-ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── GitHub Integration ────────────────────────────
# Generate at: https://github.com/settings/tokens (classic, needs repo + read:user)
GITHUB_ACCESS_TOKEN=

# ── AI Assistant (Google AI Studio) ──────────────
# Generate at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
